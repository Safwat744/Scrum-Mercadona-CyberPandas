# ─────────────────────────────────────────────
# Recetas Hacendado — Backend — Variables de Entorno
# ─────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env al repositorio.

# Base de Datos (Supabase → Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Autenticación JWT
JWT_SECRET=cambia_esto_por_una_clave_secreta_de_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# Servidor
PORT=3001
NODE_ENV=development
